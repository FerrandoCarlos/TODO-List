extends layout.pug 

block content 
    h1(class="text-3xl font-bold text-slate-800 mb-6") Mi Lista 

    //- Formulario agregar
    form(id='form-agregar',class="flex gap-2 mb-8")
        input(
            type="text",
            id="input-tarea",
            placeholder="Nueva tarea...",
            class="flex-1 border border-slate-300 rounded-lg px-4 py-2 text-slate-700 focus:outline-none"
        )
        button(type="submit",class="bg-blue-600 text-white font-semibold px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors" ) Agregar
    
    //- Lista de TODOS

    ul(id="lista-todos", class="flex flex-col gap-3")
        each todo in todos 
            li(id=`item-${todo.id}`, class="bg-white border border-slate-200 rounded-xl px-5 py-4 flex justify-between items-center shadow-sm")
                div 
                    p(class="text-slate-800 font-medium")= todo.tarea
                    span(class="text-xs text-slate-400")= todo.creado
                button(
                    class="text-red-500 border border-red-200 bg-red-50 px-3 py-1 rounded-lg text-sm font-semibold hover:bg-red-100 transition-colors",
                    onclick=`borrarTodo('${todo.id}')`
                ) Eliminar